# ============================================================
# quant-system 环境配置模板
# 复制为 .env 后修改实际值
# ============================================================

# --- 管理后台 ---
ADMIN_PASSWORD_HASH=$2a$10$xxxxxx   # bcrypt hash，用 admin-api 生成
JWT_SECRET=your-jwt-secret-hex       # 32 字节 hex 编码

# --- 加密 ---
AES_KEY=your-aes-256-key-hex         # 32 字节 hex 编码，用于 API Key 加密

# --- MySQL ---
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=quant
MYSQL_DSN=root:changeme@tcp(mysql:3306)/quant?parseTime=true

# --- NATS ---
NATS_URL=nats://nats:4222

# --- 服务地址 ---
ENGINE_CORE_ADDR=:8080
STRATEGY_RUNNER_ADDR=:8081
MARKET_INGEST_ADDR=:8082
ADMIN_API_ADDR=:8090

# --- 交易 ---
ACCOUNT_ID=default
SIMULATE_FILL=true
NATS_DELIVER_POLICY=all

# --- 行情接入 ---
INGEST_VENUE=binance
INGEST_SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT,XRP-USDT,DOGE-USDT,ADA-USDT,AVAX-USDT,LINK-USDT,DOT-USDT

# --- 飞书告警 ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=admin
