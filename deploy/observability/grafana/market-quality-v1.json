{
  "uid": "market-quality-v1",
  "title": "Market Data Quality",
  "tags": ["market", "ingest", "quality"],
  "timezone": "browser",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Ingest Event Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (result) (rate(engine_market_ingest_events_total[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Tick Rate by Symbol",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (symbol) (rate(engine_market_tick_total[1m]))",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Services Up",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=~\"market-ingest|engine-core|strategy-runner\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Down", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "Up", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "row",
      "title": "Prices",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "id": 4,
      "title": "BTC-USDT",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "engine_market_price{symbol=\"BTC-USDT\"}",
          "legendFormat": "{{side}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
